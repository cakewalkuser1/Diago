# =============================================================================
# Diago Configuration
# Copy this file to .env and fill in your values.
# All variables are optional -- Diago works fully offline with defaults.
# =============================================================================

# --- Debug Mode ---
# Set to true for verbose logging output
# DIAGO_DEBUG=false

# --- API (production) ---
# Comma-separated CORS origins (e.g. https://app.example.com). Leave empty for allow-all (local dev).
# CORS_ORIGINS=

# --- Database ---
# Custom database path (default: user data directory)
# DIAGO_DB_PATH=

# OBD2 / OBD trouble code dataset: path to a JSON file to load into the app.
# If set, this file is used to seed trouble_code_definitions (instead of the
# bundled database/obd2_codes.json). Use this if you downloaded a larger or
# custom OBD2 code library. JSON format: array of objects with keys:
# code, description, system, subsystem, mechanical_classes (array), symptoms (array), severity
# DIAGO_DB_OBD2_CODES_PATH=

# --- LLM Reasoning (Optional) ---
# Enable LLM-powered diagnostic explanations
# LLM_ENABLED=false
# LLM_PROVIDER=              # "openai", "anthropic", "ollama", or leave empty

# --- API Keys ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# TAVILY_API_KEY=            # For web search (TSBs, recalls)

# --- LLM Model Overrides ---
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# DiagBot chat: in-process by default (no Ollama required). Model auto-downloads on first use.
# Optional: custom GGUF URL (default: TinyLlama 1.1B Chat Q4_K_M)
# DIAGO_CHAT_MODEL_URL=

# Ollama (DiagBot chat). For Docker: OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_AUTO_START=false

# --- Mechanic Agent (Optional) ---
# AGENT_ENABLED=false
# MECHANIC_LLM_PROVIDER=     # "openai", "anthropic", "ollama"
# MECHANIC_OPENAI_MODEL=gpt-4o
# MECHANIC_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# MECHANIC_OLLAMA_MODEL=llama3.1
# MECHANIC_OLLAMA_URL=http://localhost:11434

# --- Audio (Advanced) ---
# DIAGO_AUDIO_SAMPLE_RATE=44100
# DIAGO_AUDIO_BANDPASS_LOW_HZ=20.0
# DIAGO_AUDIO_BANDPASS_HIGH_HZ=8000.0

# --- Supabase (Cloud Auth) ---
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=          # Found in Supabase Dashboard > Settings > API

# --- Stripe (Payments) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# DIAGO_STRIPE_PRO_PRICE_ID=price_...
# DIAGO_STRIPE_PREMIUM_PRICE_ID=price_...

# --- External APIs (Optional) ---
# CAR_API_KEY=                 # carapi.app – OBD code lookup fallback (free tier available)
