# Production: Set this to the cloud API URL for mobile/web deployment
# VITE_API_URL=https://api.diago.app

# Google Maps Platform — get key at https://console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Geocoding API
# VITE_GOOGLE_MAPS_KEY=AIza...

# Firebase — get config at https://console.firebase.google.com
# VITE_FIREBASE_API_KEY=AIza...
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123
# VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
